# ─────────────────────────────────────────────────────────────
# Akahome Signatures — environment variables
# Copy this file to `.env.local` if you want to override defaults.
# ─────────────────────────────────────────────────────────────

# WhatsApp number that customer orders are sent to.
# Full international format; spaces, dashes and a leading "+" are all fine.
# Example: +234 803 123 4567  or  +44 7700 900123
# You can also set this directly in src/lib/whatsapp.ts.
NEXT_PUBLIC_WHATSAPP_NUMBER=+000000000000

# Public site URL (used for absolute links / metadata). Optional in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
