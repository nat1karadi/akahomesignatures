# ─────────────────────────────────────────────────────────────
# Akahome Signatures — environment variables
# Copy this file to `.env.local` and drop in your real Stripe keys.
# Test mode is fine; use the TEST keys (pk_test_ / sk_test_).
# ─────────────────────────────────────────────────────────────

# Stripe SECRET key (server-only — never expose to the client).
STRIPE_SECRET_KEY=sk_test_xxxREPLACE_MExxx

# Where Stripe sends the customer after payment succeeds / is cancelled.
# These must be absolute URLs. In local dev use http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: if you later want to show the live publishable key on the client
# (e.g. for Stripe Elements), add it here. Not required for Checkout-only flow.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
